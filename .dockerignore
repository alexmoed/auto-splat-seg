# Don't ship scene data into the Docker image (it gets mounted at run
# time as a volume). The pipeline scripts and small docs come along
# via the explicit COPY step in the Dockerfile.
*.zip
*.log
logs/
docker/build_logs/

# Big scene PLYs / renders. The COPY pipeline/ step in the
# Dockerfile only copies the pipeline directory itself; the
# .dockerignore patterns below filter what's inside it during the
# build context tar.
pipeline/Kitchen_living_dining*/
pipeline/logs/
pipeline/**/*.ply
pipeline/**/diagnostics/
pipeline/**/renders/
pipeline/**/_inventory_temp/
pipeline/**/_phase1_temp/
pipeline/**/_phase2_temp/
pipeline/**/_cardinal_temp/
pipeline/**/_slice_temp/
pipeline/**/_cleanup_temp/

# Standard Python noise
**/__pycache__/
**/*.pyc
**/.pytest_cache/

# Editor / OS detritus
.vscode/
.idea/
.DS_Store
*.swp
