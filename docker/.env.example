# Copy to .env and fill in for your host. Read by docker-compose.

# Path on the host to the Qwen 3.6 35B-A3B-AWQ weights directory
# (the folder containing config.json, *.safetensors, etc.).
QWEN_WEIGHTS_HOST_PATH=/home/ubuntu/models/Qwen3.6-35B-A3B-AWQ

# Path on the host to the scene directory (the pipeline output
# folder structure: scene_dir/02_<obj>/, _inventory_temp/, etc.).
SCENE_HOST_PATH=/home/ubuntu/room_pipeline_v002/pipeline/Kitchen_living_dining_v2

# vLLM tuning (tweak for your GPU). Defaults below are L40S/A6000-48GB
# friendly: 0.75 utilization gives Qwen enough VRAM for the model +
# 8192-token context (floor_drop's iter-history prompt can exceed
# 4096), leaves headroom for SAM3 + gsplat. Drop to 0.65 on tighter
# cards; bump to 0.55 / 16384 on 80 GB H100.
QWEN_GPU_MEMORY_UTILIZATION=0.75
QWEN_MAX_MODEL_LEN=8192
